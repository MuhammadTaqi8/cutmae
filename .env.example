# /etc/bgremove.env
# !! Permissions: chmod 600 /etc/bgremove.env && chown bgremove:bgremove /etc/bgremove.env !!

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong key:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760       # 10 MB in bytes
MAX_IMAGE_WIDTH=8000
MAX_IMAGE_HEIGHT=8000
MAX_MEGAPIXELS=25.0

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=30/minute

# ── Model ─────────────────────────────────────────────────────────────────────
REMBG_MODEL=u2net
# Model weights are cached in $U2NET_HOME (default: ~/.u2net)
# U2NET_HOME=/opt/bgremove/models

# ── Workers ───────────────────────────────────────────────────────────────────
WEB_CONCURRENCY=4
WORKER_TIMEOUT=120

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
ENABLE_DOCS=false
